# Terraform state files — contain sensitive data
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform directory — auto generated
.terraform/
.terraform.lock.hcl

# Variable files — may contain secrets
*.tfvars
*.tfvars.json

# Key files — never commit
*.pem
*.key

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json